# URL del backend que CONSUME EL NAVEGADOR del usuario.
# OJO: las variables NEXT_PUBLIC_* se HORNEAN en el build (`npm run build`); no se
# leen en runtime. Si cambias esto hay que reconstruir el front.

# Desarrollo local:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Despliegue (EC2/producción): apuntar a la IP/dominio PÚBLICO del backend, p.ej.
#   NEXT_PUBLIC_API_URL=http://18.207.114.214:8000
#   NEXT_PUBLIC_API_URL=https://api.tuedad.me
# La IP pública de EC2 cambia al reiniciar la instancia (salvo Elastic IP): si el
# build queda con una IP vieja, el front llamará a un host muerto. Usa Elastic IP
# o un dominio. Ver docs/despliegue.md (sección EC2).
