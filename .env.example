# Plantilla de variables de entorno. Copiá este archivo a .env (está en .gitignore)
# y completá los valores. NUNCA commitees .env: trae credenciales de la base.
#
# Para correr el backend local cargando este archivo:
#   uvicorn api.main:app --reload --env-file .env

# =============================================================================
# OPCIÓN A — Desarrollo local contra Supabase (managed Postgres)
# =============================================================================
# Supabase: dashboard -> Connect -> Transaction pooler -> copiar el URI.
#   - usar el pooler (puerto 6543), no la conexión directa (5432)
#   - agregar ?sslmode=require al final
# Si NO se define DATABASE_URL, el backend usa SQLite local: sqlite:///data/predictions.db
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# =============================================================================
# OPCIÓN B — docker-compose (Postgres local, demo self-contained)
# =============================================================================
# Estas las consume docker-compose.yml para levantar el contenedor postgres y
# construir la DATABASE_URL interna de los servicios. NO hace falta DATABASE_URL
# arriba si usás el compose (la arma él con estos valores).
POSTGRES_USER=nhanes
POSTGRES_PASSWORD=nhanes_pass
POSTGRES_DB=nhanes_db

# =============================================================================
# Opcionales (tienen default sensato)
# =============================================================================
# Orígenes CORS permitidos (coma-separados). Default: localhost:3000 (Next.js)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Carpeta de modelos bendecidos. Default: data/09_serving
# MODEL_DIR=data/09_serving
# Ruta del contrato de features. Default: feature_schema.json
# FEATURE_SCHEMA_PATH=feature_schema.json

# =============================================================================
# Envío de informes por correo (POST /report) — TODO OPCIONAL
# =============================================================================
# Por defecto el envío corre en MODO DEMO: NO se necesita ningún secreto. El
# informe se escribe como .html en data/outbox/ y la API responde emailed=true.
# Define las tres variables SMTP_HOST/SMTP_USER/SMTP_PASSWORD para activar envío
# real vía SMTP (STARTTLS). SMTP_PORT default 587; SMTP_FROM default = SMTP_USER.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tucorreo@gmail.com
# SMTP_PASSWORD=tu_app_password
# SMTP_FROM=NHANES Longevity <tucorreo@gmail.com>
# Carpeta del outbox demo. Default: data/outbox
# MAIL_OUTBOX_DIR=data/outbox
