# Plantilla de variables de entorno. Copiá este archivo a .env (está en .gitignore)
# y completá los valores. NUNCA commitees .env: trae credenciales de la base.
#
# La API carga este archivo automáticamente al arrancar (python-dotenv). También
# podés forzarlo con: uvicorn api.main:app --reload --env-file .env

# =============================================================================
# SESIONES — login por correo (magic-link)
# =============================================================================
# Clave para firmar los tokens de sesión. Si no se define, se usa una efímera y
# las sesiones NO sobreviven reinicios. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# =============================================================================
# OPCIÓN A — Desarrollo local contra Supabase (managed Postgres)
# =============================================================================
# Supabase: dashboard -> Connect -> Transaction pooler -> copiar el URI.
#   - usar el pooler (puerto 6543), no la conexión directa (5432)
#   - agregar ?sslmode=require al final
# Si NO se define DATABASE_URL, el backend usa SQLite local: sqlite:///data/predictions.db
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# =============================================================================
# OPCIÓN B — docker-compose (Postgres local, demo self-contained)
# =============================================================================
# Estas las consume docker-compose.yml para levantar el contenedor postgres y
# construir la DATABASE_URL interna de los servicios. NO hace falta DATABASE_URL
# arriba si usás el compose (la arma él con estos valores).
POSTGRES_USER=nhanes
POSTGRES_PASSWORD=nhanes_pass
POSTGRES_DB=nhanes_db

# =============================================================================
# Opcionales (tienen default sensato)
# =============================================================================
# Orígenes CORS permitidos (coma-separados). Default: localhost:3000 (Next.js)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Carpeta de modelos bendecidos. Default: data/09_serving
# MODEL_DIR=data/09_serving
# Ruta del contrato de features. Default: feature_schema.json
# FEATURE_SCHEMA_PATH=feature_schema.json

# =============================================================================
# Envío de informes por correo (POST /report y login) — TODO OPCIONAL
# =============================================================================
# Por defecto el envío corre en MODO DEMO: NO se necesita ningún secreto. El
# informe se escribe como .html en data/outbox/ y la API responde emailed=true.
# Define SMTP_HOST/SMTP_USER/SMTP_PASSWORD para activar el envío real vía SMTP
# (STARTTLS). SMTP_PORT default 587. El código NO cambia entre proveedores: solo
# cambian estas variables.
#
# IMPORTANTE: con Resend/SendGrid, SMTP_USER NO es un correo, así que SMTP_FROM
# es OBLIGATORIO (con Gmail puede omitirse: por defecto = SMTP_USER).

# --- Opción 1 · Resend (recomendado: el más simple/moderno) -------------------
# 1) Crea cuenta en https://resend.com  2) API Keys -> Create (empieza con re_)
# 3) Sin dominio propio solo puedes enviar A TU PROPIO correo desde
#    onboarding@resend.dev (suficiente para la demo). Para enviar a cualquiera,
#    verifica un dominio (Domains -> añadir registros DNS) y usa ese From.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASSWORD=re_tu_api_key
# SMTP_FROM=NHANES Longevity <onboarding@resend.dev>

# --- Opción 2 · SendGrid (mejor si NO tienes dominio y quieres enviar a otros) -
# 1) Crea cuenta en https://sendgrid.com  2) Settings -> Sender Authentication ->
#    "Verify a Single Sender" (verifica un correo, p.ej. tu Gmail, por link).
# 3) Settings -> API Keys -> Create (empieza con SG.). SMTP_USER es literalmente
#    la palabra "apikey".
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.tu_api_key
# SMTP_FROM=NHANES Longevity <tu_correo_verificado@gmail.com>

# --- Opción 3 · Gmail (App Password; rápido pero expone tu cuenta) -------------
# Requiere 2FA + "Contraseña de aplicación" de 16 dígitos (NO tu contraseña):
# https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tucorreo@gmail.com
# SMTP_PASSWORD=abcdefghijklmnop
# SMTP_FROM=NHANES Longevity <tucorreo@gmail.com>

# Carpeta del outbox demo. Default: data/outbox
# MAIL_OUTBOX_DIR=data/outbox
